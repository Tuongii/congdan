**/.env
**/.env.local
**/.env.production
**/.env.development
**/.env.staging
**/.env.*

# Logs and databases
*.log
*.sqlite
*.sqlite3
**/*.db
**/*.db-journal
**/*.db-shm
**/*.db-wal
